# 途策留学 H5 官网 Nginx 配置示例
# 远端实际文件：/etc/nginx/conf.d/tuce.conf
# 本文件是版本控制副本，改远端配置时请同步更新此文件。
# 2026-07-08 域名切换 + SSL 上线后同步：tuce.asia 已生效，Certbot 自动续期。

server {
    # HTTPS 统一到裸域，避免 www / non-www 形成两个站点实体。
    server_name tuce.asia www.tuce.asia;
    root /var/www/tuce;
    index index.html;
    include /etc/nginx/sites-available/atlas-cache.conf;

    if ($host = www.tuce.asia) {
        return 301 https://tuce.asia$request_uri;
    }

    # 留资后端 Flask/标准库 服务反代（tuce-lead.service，监听 127.0.0.1:5000）
    # proxy_pass 不带尾斜杠：保留 /api/ 前缀，后端路由为 /api/lead
    location /api/ {
        proxy_pass http://127.0.0.1:5000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # 规范化：/index.html → /（避免首页出现两个可访问 URL）
    location = /index.html {
        # Nginx 从 / 通过 index 指令内部跳转到这里时，保留首页正常返回 200；
        # 只有用户直接请求 /index.html 才执行规范化 301。
        if ($request_uri = /index.html) {
            return 301 /;
        }
        try_files $uri =404;
    }

    # 浏览器默认会请求 /favicon.ico；统一复用品牌图标，避免无意义的 404。
    location = /favicon.ico {
        return 301 /assets/logo.webp;
    }

    # 文书训练营已并入美国本科服务，旧 URL 直接合并到主页面，避免保留 noindex 重复入口。
    location = /writing-camp {
        return 301 /meiben;
    }
    location = /writing-camp.html {
        return 301 /meiben;
    }

    # 文章页的规范 URL 保留 .html；主站页面则由下方规则隐藏 .html。
    location ^~ /articles/ {
        try_files $uri =404;
    }

    # 规范化主站页面的 trailing slash，统一到 sitemap/canonical 使用的无斜杠 URL。
    location ~ ^/(services|meiben|graduate|transfer|uk-eu|immigration|teachers|cases|blog)/$ {
        return 301 /$1$is_args$args;
    }

    location / {
        # 规范化：/page.html → /page（隐藏 .html 后缀，301 防重复内容）
        if ($request_uri ~ ^/(.+)\.html(\?.*)?$) {
            return 301 /$1$2;
        }
        try_files $uri $uri/ $uri.html =404;
    }

    location = /articles.json {
        add_header Cache-Control "no-cache";
    }

    location ~* \.(jpg|jpeg|png|gif|webp|svg|css|js|woff2|ico)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    gzip on;
    gzip_types text/plain text/css application/json application/javascript application/xml image/svg+xml;
    gzip_min_length 1024;

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/tuce.asia/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/tuce.asia/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot


}
server {
    listen 80 default_server;
    server_name tuce.asia www.tuce.asia;
    return 301 https://tuce.asia$request_uri;
}
