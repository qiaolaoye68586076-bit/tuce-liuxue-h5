---
/**
 * 3D 点阵地球「舞台」（client island）。
 * 仅负责渲染地球本体 + 悬停卡片；标题与筛选由 cases.astro 统一承载。
 * 能力检测通过 → 动态 import three chunk 并暴露 window.__globeApi；
 * 否则 html.globe-off → 由 cases.astro 切到 2D 地图。
 * 数据源仍是 cases.json（与 2D / 语义列表同源）。
 */
import cases from '../data/cases.json';
import { groupSchools, programLine } from '../lib/schools.js';

// 地球按院校聚合：一校一弧线（id 即 sid）
const payload = groupSchools(cases).map((g) => ({
  id: g.sid,
  school_zh: g.school_zh,
  school_en: g.school_en,
  region: g.region,
  years: g.years,
  count: g.count,
  programs: programLine(g),
  yearSpan: g.years.length > 1 ? `${g.years[0]}–${g.years[g.years.length - 1]}` : String(g.years[0]),
  coordinates: g.coordinates,
}));
---

<div class="gstage" id="gstage">
  <div class="gstage__stars" aria-hidden="true"></div>
  <div class="gstage__ph" aria-hidden="true"><i></i></div>
  <canvas class="gstage__canvas" id="gcanvas" aria-label="3D 录取去向地球"></canvas>
  <div class="gcard" id="gcard" hidden></div>
  <p class="gstage__hint" aria-hidden="true">拖拽旋转 · 悬停光点看案例</p>
</div>

<script type="application/json" id="gdata" set:html={JSON.stringify(payload)} is:inline></script>

<style>
  /* ===== 地球穹幕板：亮页中唯一的深色面板（保住 bloom 辉光语境） ===== */
  /* 方形取景框：圆地球 + 方框，编辑式双细线（外金边 + 内嵌发丝线）+ 四角金角标 */
  .gstage {
    position: relative;
    width: 100%; aspect-ratio: 1 / 1; max-width: 520px; margin: 0 auto;
    border-radius: 6px;
    overflow: hidden;
    background: radial-gradient(120% 130% at 60% 35%, #1c1a17 0%, #15130f 55%, #0e0d0b 100%);
    border: 1px solid rgba(182, 146, 78, 0.4);
    box-shadow: 0 30px 64px -40px rgba(20, 52, 43, 0.5),
                inset 0 0 0 1px rgba(245, 239, 230, 0.04);
  }
  /* 四角金角标（viewfinder 取景角，编辑感） */
  .gstage::before, .gstage::after {
    content: ''; position: absolute; z-index: 5; width: 18px; height: 18px; pointer-events: none;
    border: 1.5px solid rgba(182, 146, 78, 0.7);
  }
  .gstage::before { top: 12px; left: 12px; border-right: 0; border-bottom: 0; }
  .gstage::after  { bottom: 12px; right: 12px; border-left: 0; border-top: 0; }

  /* 低调星点：散落四周，地球盖住中央，仅作氛围（克制但看得见） */
  .gstage__stars {
    position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background-repeat: no-repeat;
    background-image:
      radial-gradient(2.4px 2.4px at 9% 16%, rgba(245, 250, 247, 0.95), transparent 62%),
      radial-gradient(1.6px 1.6px at 17% 74%, rgba(235, 245, 240, 0.75), transparent 62%),
      radial-gradient(2.6px 2.6px at 24% 33%, rgba(240, 230, 205, 0.85), transparent 62%),
      radial-gradient(1.5px 1.5px at 6% 52%, rgba(235, 245, 240, 0.70), transparent 62%),
      radial-gradient(2px 2px at 31% 88%, rgba(235, 245, 240, 0.80), transparent 62%),
      radial-gradient(1.6px 1.6px at 47% 6%, rgba(235, 245, 240, 0.72), transparent 62%),
      radial-gradient(2.3px 2.3px at 66% 93%, rgba(235, 245, 240, 0.82), transparent 62%),
      radial-gradient(1.8px 1.8px at 80% 20%, rgba(240, 230, 205, 0.80), transparent 62%),
      radial-gradient(2.6px 2.6px at 92% 38%, rgba(245, 250, 247, 0.95), transparent 62%),
      radial-gradient(1.6px 1.6px at 86% 68%, rgba(235, 245, 240, 0.70), transparent 62%),
      radial-gradient(2.2px 2.2px at 96% 86%, rgba(235, 245, 240, 0.84), transparent 62%),
      radial-gradient(1.5px 1.5px at 74% 52%, rgba(235, 245, 240, 0.60), transparent 62%),
      radial-gradient(1.7px 1.7px at 38% 60%, rgba(235, 245, 240, 0.55), transparent 62%),
      radial-gradient(2px 2px at 58% 78%, rgba(235, 245, 240, 0.66), transparent 62%);
    opacity: 0; transition: opacity 1.4s ease 0.2s;
    animation: gstarTwinkle 6s ease-in-out infinite;
  }
  .gstage.ready .gstage__stars { opacity: 1; }
  @keyframes gstarTwinkle { 0%, 100% { filter: brightness(0.75); } 50% { filter: brightness(1.2); } }

  .gstage__canvas {
    position: absolute; inset: 0; z-index: 1; width: 100% !important; height: 100% !important;
    display: block; opacity: 0; transition: opacity 1.1s ease;
  }
  .gstage.ready .gstage__canvas { opacity: 1; }

  /* 加载占位：与最终构图一致（居中细环 + 微光），杜绝白屏闪烁 */
  .gstage__ph { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; transition: opacity 0.9s ease; }
  .gstage__ph i {
    width: min(64%, 420px); aspect-ratio: 1; border-radius: 50%;
    border: 1px solid rgba(0, 168, 107, 0.22);
    box-shadow: 0 0 120px rgba(0, 88, 57, 0.35) inset, 0 0 90px rgba(0, 88, 57, 0.18);
  }
  .gstage.ready .gstage__ph { opacity: 0; }

  /* 操作提示：右下角浮字 */
  .gstage__hint {
    position: absolute; left: 16px; bottom: 14px; z-index: 6;
    font-size: 11.5px; letter-spacing: 0.06em;
    color: rgba(244, 239, 230, 0.62);
    opacity: 0; transition: opacity 0.9s ease 0.3s; pointer-events: none;
  }
  .gstage.ready .gstage__hint { opacity: 1; }

  /* ===== 深色磨砂玻璃案例卡 ===== */
  .gcard {
    position: absolute; z-index: 10; width: 232px; pointer-events: none;
    background: rgba(28, 26, 23, 0.74);
    -webkit-backdrop-filter: blur(10px); backdrop-filter: blur(10px);
    border: 1px solid rgba(0, 168, 107, 0.45);
    border-radius: 6px; padding: 13px 15px;
    transform: translate(16px, -50%);
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.45);
  }
  .gcard.flip { transform: translate(calc(-100% - 16px), -50%); }
  .gcard :global(h4) { font-family: var(--font-serif); font-size: 15px; font-weight: 700; color: #f4efe6; line-height: 1.4; }
  .gcard :global(.en) { font-size: 11px; letter-spacing: 0.04em; color: rgba(244, 239, 230, 0.5); }
  .gcard :global(.prog) { margin-top: 8px; font-size: 13px; color: #7fdcb0; }
  .gcard :global(.meta) { margin-top: 4px; font-size: 12px; color: rgba(244, 239, 230, 0.55); }

  @media (prefers-reduced-motion: reduce) {
    .gstage__canvas, .gstage__ph, .gstage__hint, .gstage__stars { transition: none; }
    .gstage__stars { animation: none; }
  }
</style>

<script>
  const root = document.documentElement;
  const stage = document.getElementById('gstage')!;
  const canvas = document.getElementById('gcanvas') as HTMLCanvasElement;
  const card = document.getElementById('gcard')!;
  const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

  function webglOK(): boolean {
    try {
      const c = document.createElement('canvas');
      return !!(c.getContext('webgl2') || c.getContext('webgl'));
    } catch { return false; }
  }
  const nav = navigator as Navigator & { deviceMemory?: number };
  const lowEnd = (nav.hardwareConcurrency || 8) <= 2 || (nav.deviceMemory !== undefined && nav.deviceMemory < 4);
  const desktop = matchMedia('(hover: hover) and (pointer: fine)').matches && innerWidth >= 768;
  const use3D = desktop && webglOK() && !lowEnd;

  type Row = {
    id: string; school_zh: string; school_en: string; region: string;
    years: number[]; count: number; programs: string; yearSpan: string;
    coordinates: [number, number];
  };
  const data: Row[] = JSON.parse(document.getElementById('gdata')!.textContent!);
  const byId = Object.fromEntries(data.map((c) => [c.id, c]));

  if (!use3D) {
    root.classList.add('globe-off');           // 2D 版（cases.astro 兜底）即回退
  } else {
    // 乐观先亮：立即显示地球舞台、隐藏 2D 图。
    // 必须同步加 globe-on——否则 #gstage 仍 display:none，IntersectionObserver
    // 永不触发，地球无法初始化（会假性退回 2D「平面地球」）。
    root.classList.add('globe-on');

    function onHover(id: string | null, x: number, y: number) {
      if (!id) { card.hidden = true; return; }
      const c = byId[id];
      card.innerHTML =
        `<h4>${c.school_zh}</h4><p class="en">${c.school_en}</p>` +
        `<p class="prog">${c.count} 枚 Offer · ${c.yearSpan}</p>` +
        `<p class="meta">${c.programs}</p>`;
      card.style.left = x + 'px';
      card.style.top = y + 'px';
      card.classList.toggle('flip', x > stage.clientWidth * 0.55);
      card.hidden = false;
    }

    const io = new IntersectionObserver(async (en) => {
      if (!en[0].isIntersecting) return;
      io.disconnect();
      try {
        const mod = await import('../three/globe/index');
        const api = await mod.createGlobe({
          container: stage, canvas, cases: data,
          dotsUrl: '/globe-dots.json', reduced, onHover,
        });
        stage.classList.add('ready');
        (window as any).__globeApi = api;        // cases.astro 的共享筛选驱动它
        // 若用户在地球加载前已筛选，进场即对齐当前筛选状态
        const pending = (window as any).__caseFilter as { region: string; year: string } | undefined;
        if (pending && (pending.region !== 'all' || pending.year !== 'all')) {
          api.setFilter(pending.region, pending.year);
        }
      } catch (e) {
        console.warn('[globe] WebGL init failed, fallback to 2D:', e);
        root.classList.remove('globe-on');       // 撤销乐观态，真正退回 2D
        root.classList.add('globe-off');
      }
    }, { threshold: 0.1 });
    io.observe(stage);
  }
</script>
