# scripts/sync_articles.env.example
# ─────────────────────────────────────────────────────────────────────────────
# 复制为同目录的 .env（已被 .gitignore 忽略，切勿提交真实密钥），填好后：
#   set -a; source scripts/.env; set +a; python3 scripts/sync_articles.py
# cron 里则用：env $(grep -v '^#' /opt/tuce-liuxue-h5/scripts/.env | xargs) python3 ...
# ─────────────────────────────────────────────────────────────────────────────

# 【source=auto/material/freepublish 时必填】公众号 AppID / AppSecret
#   （公众号后台 → 设置与开发 → 基本配置；source=tikhub 时用不到）
WX_APPID=wx_your_appid_here
WX_APPSECRET=your_appsecret_here

# 【服务器必填】前端 web 根目录 = 线上站点目录（与 deploy.sh 的 ECS_PATH 一致）
#   本地调试可不填，默认写到 ../frontend
TUCE_WEB_ROOT=/var/www/tuce

# 数据源：
#   tikhub —— 第三方接口，取公众号主页「文章」tab 的全量历史发文（推荐：官方 freepublish
#             抓不到「群发未发表 / 图片 / 第三方排版」发的文章，tikhub 能拿到）
#   auto / material / freepublish —— 微信官方接口（需上面的 WX_APPID / WX_APPSECRET）
WX_ARTICLE_SOURCE=tikhub

# 【source=tikhub 时必填】TikHub API key（https://tikhub.io，Authorization: Bearer 认证）
TIKHUB_KEY=
# 【source=tikhub 时必填】公众号 gh_ 原始ID（后台→设置与开发→公众号设置→原始ID，非 AppID）
WX_GH_USERNAME=

# 最多保留多少篇
WX_MAX_ARTICLES=30

# 每次最多翻几页（每页≈10篇，每页计费一次 ≈ $0.01）：
#   0 = 全量：翻到 WX_MAX_ARTICLES 为止（首次同步 / 重建时用）
#   1 = 增量：只取最新一页，与已有 articles.json 合并去重（日常 cron 省钱，推荐）
WX_FETCH_PAGES=1

# 是否下载封面到本地 assets/insights/（1 开 0 关）。
# mmbiz 图片直链有防盗链，跨域 <img> 易 403，强烈建议保持 1。
WX_DOWNLOAD_COVERS=1

# 标题关键词都命中不到时的兜底分类
# （可选：英国地区 / 美国地区 / 香港·新加坡 / 澳洲·加拿大 / 专业解读）
WX_DEFAULT_CATEGORY=美国地区
